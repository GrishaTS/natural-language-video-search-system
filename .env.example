# ── Versioning ────────────────────────────────────────────────
VERSION=0.1.0

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=postgres-nlv-search
POSTGRES_PORT=5432
POSTGRES_DB=nlv_search
POSTGRES_USER=nlv_user
POSTGRES_PASSWORD=change_me

# ── Qdrant ────────────────────────────────────────────────────
QDRANT_HOST=qdrant-nlv-search
QDRANT_PORT=6333
QDRANT_API_KEY=change_me

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis-nlv-search
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=change_me

# ── MinIO ─────────────────────────────────────────────────────
MINIO_HOST=minio-nlv-search
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=nlv-search
MINIO_ROOT_USER=minio_user
MINIO_ROOT_PASSWORD=change_me

# ── Backend ───────────────────────────────────────────────────
BACKEND_HOST=backend-nlv-search
BACKEND_PORT=8000
BACKEND_PUBLISHED_PORT=8000
BACKEND_LOG_LEVEL=info
BACKEND_WORKERS=1
BACKEND_RELOAD=true
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# ── Auth ──────────────────────────────────────────────────────
AUTH_SECRET_KEY=change_me_to_a_long_random_string
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD_HASH=change_me
SERVICE_TOKEN=change_me
DEFAULT_USER_PASSWORD=change_me

# ── AI service ────────────────────────────────────────────────
AI_HOST=ai-nlv-search
AI_PORT=8501
AI_LOG_LEVEL=info
AI_RELOAD=true

# ── vLLM ──────────────────────────────────────────────────────
VLLM_URL=http://localhost:8080/v1
VLLM_API_KEY=change_me
VLLM_MODEL=Qwen/Qwen3-8B

# ── TEI (Text Embeddings Inference) ──────────────────────────
TEI_URL=http://tei-nlv-search:80
TEI_PORT=8502
NVIDIA_VISIBLE_DEVICES=all

# ── VMS (Video Management System) ────────────────────────────
VMS_API_URL=http://your-vms-host
VMS_BEARER_TOKEN=
VMS_USERNAME=
VMS_PASSWORD=
VMS_FRONTEND_URL=http://your-vms-host

# ── Bot user (optional) ───────────────────────────────────────
NLV_BOT_USERNAME=
NLV_BOT_PASSWORD=

# ── Frontend ──────────────────────────────────────────────────
FRONTEND_PORT=3000
VITE_BACKEND_URL=http://localhost:8000
